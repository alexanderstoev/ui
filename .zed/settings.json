{
  "format_on_save": "on",
  "languages": {
    "CSS": {
      "language_servers": [
        "tailwindcss-language-server",
        "!css-languageserver",
      ],
    },
    "TypeScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
        "source.organizeImports": true,
      },
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": [
            "exec",
            "prettier",
            "--stdin-filepath",
            "{buffer_path}",
          ],
        },
      },
    },
    "TSX": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
        "source.organizeImports": true,
      },
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": [
            "exec",
            "prettier",
            "--stdin-filepath",
            "{buffer_path}",
          ],
        },
      },
    },
  },
  "lsp": {
    "emmet-language-server": {
      "settings": {
        "langiages": ["TSX"],
      },
    },
    "vtsls": {
      "settings": {
        "typescript": {
          "preferences": {
            "importModuleSpecifier": "non-relative",
            "importModuleSpecifierEnding": "minimal",
          },
        },
      },
    },
    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "css": "html",
        },
      },
    },
  },
}
