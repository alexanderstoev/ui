{
  "format_on_save": "on",
  "languages": {
    "CSS": {
      "language_servers": [
        "tailwindcss-language-server",
        "!css-languageserver",
      ],
    },
    "TypeScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
        "source.organizeImports": true,
      },
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--write", "--stdin-filepath", "{buffer_path}"],
        },
      },
    },
    "TSX": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
        "source.organizeImports": true,
      },
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--write", "--stdin-filepath", "{buffer_path}"],
        },
      },
    },
  },
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "css": "html",
        },
      },
    },
  },
}
